# .NET
bin/
obj/
*.user
*.suo
[Tt]est[Rr]esults/

# Godot 4
.godot/
.import/
export.cfg
# NOTE: export_presets.cfg IS tracked (the windows-client/linux-dedicated presets carry no
# secrets — no keystores/credentials; Godot keeps those in export_credentials.cfg, which stays
# ignored via .godot/).
mono_crash.*.json
# NOTE: *.cs.uid files are intentionally committed (Godot 4.4+ guidance) for
# stable script UIDs across machines/checkouts. Do NOT add *.uid here.

# IDE
.vs/
.idea/
.vscode/

# Visual-capture output (--screenshot; see RUNNING.md "Visual capture"). The
# .gdignore IS tracked so the Godot editor skips this tree (no *.import sidecars
# for captured PNGs) even on a fresh checkout before anything is captured.
screenshots/*
!screenshots/.gdignore
# Stray captures dropped in the project root (prefer _scratch/ below).
_*.png

# Local scratch / throwaway dev files (test textures, comparison captures, one-off
# experiments). Same deal as assets/ and screenshots/: the folder is .gdignore'd so
# Godot never imports it (no *.import noise) and the contents are git-ignored. The
# two marker files stay tracked so a fresh checkout has the folder ready to use.
_scratch/*
!_scratch/.gdignore
!_scratch/README.md

# Export/packaging output (export presets + tools/package.sh). Test-run artifacts
# (TestResults/) are already covered by the [Tt]est[Rr]esults/ rule above.
/dist/

# Compiled golden-trace generator (the .c source + the generated golden/*.json fixtures ARE tracked)
/tools/movement-ref/movement_ref
/tools/movement-ref/movement_ref.exe

# Downloaded game assets (populated by download-assets.sh). The .gdignore IS tracked
# so the Godot editor skips this tree (the game reads it via its own VFS, not Godot's
# resource importer) even on a fresh checkout before the assets are downloaded.
assets/*
!assets/.gdignore

# OS
Thumbs.db
desktop.ini
.DS_Store

# Dev launch log artifact
_game_menu.log
