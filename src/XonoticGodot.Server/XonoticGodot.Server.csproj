<Project Sdk="Microsoft.NET.Sdk">
  <!-- Server-only orchestration (the C# analogue of qcsrc/server/): the game world loop, client
       management, scores, teamplay, round/match flow, voting, and the bot AI. Godot-free so the
       dedicated server runs headless (ADR-0008/0012). References Common (gameplay) + Engine (sim). -->
  <PropertyGroup>
    <TargetFramework>$(XonoticGodotTfm)</TargetFramework>
    <RootNamespace>XonoticGodot.Server</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\XonoticGodot.Common\XonoticGodot.Common.csproj" />
    <ProjectReference Include="..\XonoticGodot.Engine\XonoticGodot.Engine.csproj" />
  </ItemGroup>
</Project>
