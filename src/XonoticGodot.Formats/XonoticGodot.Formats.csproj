<Project Sdk="Microsoft.NET.Sdk">
  <!-- Binary asset PARSERS (IBSP v46, MD3/IQM/DPM) producing engine-neutral POCO data.
       Godot-free so parsing is unit-testable; the Godot host turns the data into ArrayMesh/Skeleton3D.
       (Refinement of ADR-0006 for buildability/testability.) -->
  <PropertyGroup>
    <TargetFramework>$(XonoticGodotTfm)</TargetFramework>
    <RootNamespace>XonoticGodot.Formats</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\XonoticGodot.Common\XonoticGodot.Common.csproj" />
  </ItemGroup>
</Project>
