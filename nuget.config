<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Godot 4.6.3-stable ships its Godot.NET.Sdk / GodotSharp / source-generator packages in the editor's
       local nupkgs folder (the stable patch release isn't published to nuget.org). Add it as a source so
       `dotnet build XonoticGodot.csproj` resolves the same packages the editor uses. -->
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="godot-editor" value="C:\Program Files\Godot\GodotSharp\Tools\nupkgs" />
  </packageSources>
</configuration>
