<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Godot 4.6.3-stable ships its Godot.NET.Sdk / GodotSharp / source-generator packages in the editor's
       local nupkgs folder. Keeping it as a source guarantees `dotnet build XonoticGodot.csproj` resolves the
       EXACT packages the installed editor uses (and works offline). Godot.NET.Sdk/GodotSharp 4.6.3 ARE also
       published on nuget.org (verified 2026-06), which is what CI uses: .github/workflows/ci.yml removes the
       "godot-editor" source (this Windows path doesn't exist on a Linux runner and NuGet hard-fails on a
       missing local source) and restores everything from nuget.org. Keep the key name "godot-editor" stable —
       the CI remove-source step targets it by name. -->
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="godot-editor" value="C:\Program Files\Godot\GodotSharp\Tools\nupkgs" />
  </packageSources>
</configuration>
