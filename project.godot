; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="XonoticGodot"
config/description="Xonotic, reborn on Godot + C#. See planning/."
run/main_scene="res://Main.tscn"
; r16 rubberband ROOT CAUSE: Godot's delta smoothing (default ON) snaps every _Process delta onto a grid
; derived from the DETECTED refresh rate — which this platform misreads as 60Hz on high-refresh panels
; (the known borderless under-report; see ClientSettings' auto-cap note). On a 143Hz display the sim was
; fed 8.33/11.11/16.67ms quantized deltas while real frames ran otherwise — everything moved measurably
; slow-then-fast (the motion trace caught 11.11ms-constant deltas over 8.33ms wall frames = 33% slow).
; Raw measured deltas are DP-faithful (cl.realframetime) and what every timing system here expects.
run/delta_smooth=false
config/features=PackedStringArray("4.6", "C#", "Forward Plus")

[dotnet]

project/assembly_name="XonoticGodot"

[physics]

; (perf 2.0 / R30, 2026-07-06) The game runs its OWN 72 Hz sim + collision (TraceService/CollisionWorld);
; Godot's physics serves NOTHING today: zero body/area/query users (BuildCollisionMesh is caller-less, the
; casings/gibs _PhysicsProcess nodes never spawn - see planning/perf-campaign-2026-07-06.md Phase 1c: the
; 60 Hz phase cost 0.15-0.39 ms/frame for nothing, and catch-up steps amplified hitches). 10 Hz + a 1-step
; cap keeps the phase alive for future opt-ins (ragdolls) at ~zero cost. If a real Godot-physics consumer
; ever lands, raise these deliberately. (Godot strips these comments on re-serialise - rationale lives in
; the campaign doc.)
common/physics_ticks_per_second=10
common/max_physics_steps_per_frame=1

[rendering]

; r16 queue-elasticity EXPERIMENT (the DP-vs-port present difference candidate): Godot's flip-model
; swapchain queues 2-3 frames; producing faster than the 143Hz compositor consumes makes queue occupancy
; (= view latency) oscillate continuously - a rubberband MECHANISM that doesn't require DP to be
; "cheaper", just unqueued (DP presents immediately: GDI copy / immediate flip). Minimal queue = minimal
; elasticity. Revert both if this regresses throughput.
rendering_device/vsync/frame_queue_size=1
rendering_device/vsync/swapchain_image_count=2

textures/default_filters/anisotropic_filtering_level=3
anti_aliasing/quality/msaa_3d=2
; (engine-perf 2026-06-16) Dither the final image to kill banding in the sky / large gradients. A pipeline-key
; change set once at boot (never toggled mid-match) so it costs nothing at runtime — ~0 CPU, sub-ms GPU, and
; we're GPU-idle. The warm SubViewport copies UseDebanding from the live viewport, so warmed variants match.
; (NOTE: Godot strips these comments whenever it re-serialises project.godot — e.g. on export. Rationale also
; lives in planning/engine-optimization-2026-06-15.md. The Vulkan RD driver is already the verified default —
; "Vulkan 1.4.341 - Forward+" — so no rendering_device/driver.windows pin is needed; Godot drops it as redundant.)
anti_aliasing/quality/use_debanding=true
; Allocates the software occlusion-culling buffer so OccluderInstance3D works. Per-viewport opt-in still
; gates it: only the game viewport turns it on (via the r_occlusion_cull cvar / WorldOcclusion); the menu
; viewport leaves Viewport.use_occlusion_culling=false, so this is ~free until a map enables the A/B path.
occlusion_culling/use_occlusion_culling=true
; Required for the macOS universal/arm64 export (the Apple-Silicon slice uses ETC2/ASTC, not S3TC/BPTC).
; Harmless for the Windows/Linux exports — their presets don't include the etc2_astc texture variants.
textures/vram_compression/import_etc2_astc=true
